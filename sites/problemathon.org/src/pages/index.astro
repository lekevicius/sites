      <h1 class="mt-6 sm:mt-20 mx-auto logo">Problemathon</h1>
      <p class="mx-auto text-4xl leading-8 text-center mt-2 sm:mb-8 mb-12">
        Micro conference &<br />
        think tank for a weekend
      </p>
      <div class="date text-4xl text-center mb-8">April 21-23, Vilnius</div>
      <div class="info-line flex flex-col sm:flex-row gap-6 sm:gap-12 items-center justify-center">
        <a href="https://vilniustechfusion.com/en/" class="sponsor-item flex text-right leading-4 items-center gap-4">
          <span>
            Powered <br />
            by
          </span>
          <img src={partnerVilniusTechFusionInlineLogo.src} alt="Vilnius TechFusion" />
        </a>
        <a href="https://firstpick.notion.site/FIRSTPICK-62c5f26d91aa4c7193d8c7886a30e58f" class="sponsor-item flex text-right leading-4 items-center gap-4">
          <span>
            Accelerated <br />
            by
          </span>
          <img src={partnerFirstPickInlineLogo.src} alt="FIRSTPICK" />
        </a>
        <a href="https://www.ism.lt/en/" class="sponsor-item flex text-right leading-4 items-center gap-4">
          <span>
            Hosted <br />
            by
          </span>
          <img src={partnerISMInlineLogo.src} alt="ISM" />
        </a>
      </div>
      <hr class="hr sm:-mx-16 h-1 border-0 my-12" />
    </section>
    <nav class="flex justify-center font-nanum text-3xl">
      {/* sticky top-0 py-4 -mx-4 bg-[#eef0f3] */}
      <ul class="flex flex-col sm:flex-row items-center gap-2 sm:gap-10">
        <li>
