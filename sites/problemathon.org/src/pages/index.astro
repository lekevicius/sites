<Layout
  title="Problemathon"
  description="It’s time to solve real problems. Join us for a weekend-long problemathon. The event is designed for cross-discipline thinking, focused on identifying key problems and sustainable solutions."
  url="https://problemathon.org/"
  author="Problemathon Team"
  twitter="@problemathon"
